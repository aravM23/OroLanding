# Vercel environment variables for oro-landing (buildingoro.ca).
# Set these in the Vercel dashboard → Project → Settings → Environment Variables.

# Supabase — use the SERVICE ROLE key (not anon) so the unsubscribe endpoint can write.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# HMAC secret for unsubscribe tokens — must match UNSUBSCRIBE_SECRET in oro-newsletter/.env.local.
# Generate with: openssl rand -base64 48
UNSUBSCRIBE_SECRET=
